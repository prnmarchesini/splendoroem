# ===== Aplicação =====
APP_NAME=Splendor O&M API
ENVIRONMENT=development
PORT=8000

# ===== Supabase =====
# Encontre em: Supabase > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Chave service_role / "secret" (uso EXCLUSIVO no backend — nunca exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ===== Railway =====
# Project token: Railway > Project Settings > Tokens
RAILWAY_TOKEN=seu-project-token-aqui

# ===== CORS =====
# Origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:5173
